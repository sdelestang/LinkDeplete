## Project to determine catch to fish to push biomas to 40% unfished
# Recent 5-year average recruitment
rows_R   <- rownames(sdr_est) == "log_Brec_vec"
R_recent <- mean(tail(exp(sdr_est[rows_R, "Estimate"]), 5))

# End-of-season biomass: fished and unfished (most recent year)
B_end_last  <- exp(tail(sdr_est[rownames(sdr_est) == "log_Bend_vec", "Estimate"], 1))
B0_end_last <- exp(tail(sdr_est[rownames(sdr_est) == "log_B0mid_vec", "Estimate"], 1))

# Need B0 end-of-season — reconstruct from B0_mid by running remaining timesteps
# Actually better: ADREPORT a log_B0end_vec from the model

# For now, approximate B0_end from B0_mid:
# B0_mid is at ref_ts, then M applies for remaining (TS - ref_ts) months
B0_mid_last <- exp(tail(sdr_est[rownames(sdr_est) == "log_B0mid_vec", "Estimate"], 1))
B0_end_last <- B0_mid_last * exp(-dat$M * (dat$TS - dat$ref_ts))

# Catch split from recent data
fish_steps  <- which(colMeans(tail(catch_mat, 5)) > 0)
avg_monthly <- colMeans(tail(catch_mat, 5))[fish_steps]
catch_split <- avg_monthly / sum(avg_monthly)

# Solve for catch giving 40% depletion
result <- uniroot(
  function(C) project_depletion_end(C, B_end_last, B0_end_last, R_recent, dat$M,
                                    catch_split, fish_steps, dat$rec_ts, dat$TS) - dat$ref_levels[1],
  interval = c(0, B_end_last + R_recent),
  tol = 0.01
)

cat("Recent 5-yr avg recruitment:", round(R_recent, 1), "t\n")
cat("B_end (fished, latest):     ", round(B_end_last, 1), "t\n")
cat("B0_end (unfished, latest):  ", round(B0_end_last, 1), "t\n")
cat("Target depletion:            0.40\n")
cat("Target catch:               ", round(result$root, 1), "t\n")
cat("Target catch (kg):          ", round(result$root * 1000, 0), "kg\n")
